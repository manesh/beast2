2 .c functions for blue2 code training





Here are 2 small .c functions that fit Blue2-style training:
	•	one for anchored vector update
	•	one for state transition with your -1 0 1 maybe logic

#include <stddef.h>
#include <string.h>

#define BLUE2_DIM 16

/* maybe/state values */
#define BLUE2_REJECTED (-1)
#define BLUE2_UNKNOWN   0
#define BLUE2_VERIFIED  1

/* 1) update a mutable vector toward a target, but never modify anchors */
void blue2_update_vector(
    const char *token,
    const char *const *anchors,
    size_t anchor_count,
    float vec[BLUE2_DIM],
    const float target[BLUE2_DIM],
    float learning_rate
) {
    if (token == NULL || vec == NULL || target == NULL) {
        return;
    }

    /* freeze anchor words */
    for (size_t i = 0; i < anchor_count; i++) {
        if (anchors[i] != NULL && strcmp(token, anchors[i]) == 0) {
            return;
        }
    }

    /* simple move-toward-target update */
    for (size_t i = 0; i < BLUE2_DIM; i++) {
        float error = target[i] - vec[i];
        vec[i] += learning_rate * error;
    }
}

/* 2) captain-style state transition for maybe entries */
int blue2_update_state(int current_state, int captain_signal) {
    /* captain_signal:
       -1 -> rejected
        0 -> leave unchanged
        1 -> verified
    */

    if (captain_signal == BLUE2_REJECTED) {
        return BLUE2_REJECTED;
    }

    if (captain_signal == BLUE2_VERIFIED) {
        return BLUE2_VERIFIED;
    }

    /* unknown / no change */
    return current_state;
}

What they teach Blue2

blue2_update_vector(...)
	•	words can move in vector space
	•	anchor words stay fixed
	•	learning is gradual, not magic

blue2_update_state(...)
	•	-1 = rejected
	•	0 = unknown / unchanged
	•	1 = verified

Example use

const char *anchors[] = {
    "up", "down", "left", "right", "forward", "backward"
};

float advance[BLUE2_DIM] = {0};
float forward_target[BLUE2_DIM] = {0};
forward_target[2] = 1.0f; /* forward axis */

blue2_update_vector(
    "advance",
    anchors,
    6,
    advance,
    forward_target,
    0.25f
);

int knight_state = BLUE2_UNKNOWN;
knight_state = blue2_update_state(knight_state, BLUE2_VERIFIED);

