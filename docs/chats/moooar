ultra-simple Python sketch

from typing import List
import math
import random

VOCAB = ["yes", "no"]

def sigmoid(x: float) -> float:
    return 1.0 / (1.0 + math.exp(-x))

def tiny_yes_no_model(features: List[float], steps: int = 3) -> List[str]:
    # toy hand-coded weights
    weights = [0.8, -0.5, 0.3]
    bias = 0.0

    score = sum(f * w for f, w in zip(features, weights[:len(features)])) + bias
    p_yes = sigmoid(score)

    out = []
    for _ in range(steps):
        out.append("yes" if random.random() < p_yes else "no")
        # optional tiny state update
        p_yes = max(0.05, min(0.95, p_yes * 0.9 + 0.05))
    return out

print(tiny_yes_no_model([1.0, 0.0, 1.0], steps=3))

