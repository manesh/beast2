step B: planner

bool beastPlanJobsFromCommand(
    const BeastParsedCommand *cmd,
    BeastJob *outJobs,
    uint32_t maxJobs,
    uint32_t *outJobCount)
{
    *outJobCount = 0;

    switch (cmd->action) {
        case BEAST_CMD_QUEUE_IMAGE_GEN: {
            if (maxJobs < 1) return false;

            BeastJob *job = &outJobs[0];
            *job = (BeastJob){0};
            job->type = BEAST_JOB_QUEUE_IMAGE_GEN;
            job->status = BEAST_JOB_STATUS_CREATED;

            snprintf(job->payload.queueImageGen.positivePrompt,
                     sizeof(job->payload.queueImageGen.positivePrompt),
                     "%s", cmd->positivePrompt);

            snprintf(job->payload.queueImageGen.modelName,
                     sizeof(job->payload.queueImageGen.modelName),
                     "%s", cmd->modelName);

            *outJobCount = 1;
            return true;
        }

        case BEAST_CMD_LOAD_THUMBNAIL: {
            if (maxJobs < 1) return false;

            BeastJob *job = &outJobs[0];
            *job = (BeastJob){0};
            job->type = BEAST_JOB_LOAD_THUMBNAIL;
            job->status = BEAST_JOB_STATUS_CREATED;

            snprintf(job->payload.loadThumbnail.artifactPath,
                     sizeof(job->payload.loadThumbnail.artifactPath),
                     "%s", cmd->artifactPath);

            job->payload.loadThumbnail.maxWidth = 256;
            job->payload.loadThumbnail.maxHeight = 256;

            *outJobCount = 1;
            return true;
        }

        default:
            return false;
    }
}

step C: submit planned jobs

bool beastDispatchPlannedJobs(
    BeastDispatcher *dispatcher,
    BeastJob *jobs,
    uint32_t jobCount)
{
    for (uint32_t i = 0; i < jobCount; ++i) {
        if (!beastSubmitJob(dispatcher, &jobs[i])) {
            return false;
        }
    }
    return true;
}


