static BeastJobResult beastExecuteJob(const BeastJob *job) {
    switch (job->type) {
        case BEAST_JOB_DRAW_GALLERY:
            return beastExecuteDrawGallery(&job->payload.drawGallery, job->id);

        case BEAST_JOB_QUEUE_IMAGE_GEN:
            return beastExecuteQueueImageGen(&job->payload.queueImageGen, job->id);

        case BEAST_JOB_LOAD_THUMBNAIL:
            return beastExecuteLoadThumbnail(&job->payload.loadThumbnail, job->id);

        case BEAST_JOB_DB_WRITE:
            return beastExecuteDbWrite(&job->payload.dbWrite, job->id);

        default: {
            BeastJobResult result = {0};
            result.id = job->id;
            result.type = job->type;
            result.resultType = BEAST_JOB_RESULT_FAILURE;
            result.errorCode = 1;
