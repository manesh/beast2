hmm what would it take to do the same in sdl3










Much less than with sokol.

If the goal is "open window, clear screen, draw one draggable rectangle," SDL3 is a bit more direct because it already gives you:
	•	window creation
	•	event loop
	•	renderer
	•	geometry drawing

SDL3’s renderer API includes SDL_RenderGeometry, which is available in SDL 3.2.0+, and rendering calls like that are documented as main-thread-only. SDL3 also requires #include <SDL3/SDL_main.h> in the file with main(), per the migration guide.  ￼

what it would take conceptually

With SDL3, the equivalent of your sokol starter is:

init SDL
create window
create renderer
run event loop
update app state from events
draw rectangle with SDL_RenderGeometry or SDL_RenderFillRect
present frame
shutdown

That is a shorter path than sokol because SDL already owns more of the platform plumbing. SDL itself describes SDL3 as the current stable version and positions it as the cross-platform layer for windowing, input, rendering, audio, and more.  ￼

simplest SDL3 version

You do not even need geometry for the first shell.
You can start with SDL_RenderFillRect().

That means your first Beast shell can be:
	•	one SDL_Window*
	•	one SDL_Renderer*
	•	one BeastApp state struct
	•	one event loop
	•	one beastUpdate()
	•	one beastDraw()

minimal starter skeleton

#include <SDL3/SDL.h>
#include <SDL3/SDL_main.h>
#include <stdbool.h>

typedef struct BeastRect {
    float x;
    float y;
    float w;
    float h;
} BeastRect;

typedef struct BeastInput {
    float mouseX;
    float mouseY;
    bool mouseDown;
} BeastInput;

typedef struct BeastApp {
    SDL_Window *window;
    SDL_Renderer *renderer;
    bool running;
    BeastInput input;
    BeastRect rect;
} BeastApp;

static bool beastPointInsideRect(float x, float y, const BeastRect *r) {
    return x >= r->x && x <= (r->x + r->w) &&
           y >= r->y && y <= (r->y + r->h);
}

static void beastHandleEvent(BeastApp *app, const SDL_Event *event) {
    switch (event->type) {
        case SDL_EVENT_QUIT:
            app->running = false;
            break;

        case SDL_EVENT_MOUSE_MOTION:
            app->input.mouseX = event->motion.x;
            app->input.mouseY = event->motion.y;
            break;

        case SDL_EVENT_MOUSE_BUTTON_DOWN:
            app->input.mouseDown = true;
            app->input.mouseX = event->button.x;
            app->input.mouseY = event->button.y;
            break;

        case SDL_EVENT_MOUSE_BUTTON_UP:
            app->input.mouseDown = false;
            app->input.mouseX = event->button.x;
            app->input.mouseY = event->button.y;
            break;

        default:
            break;
    }
}

static void beastUpdate(BeastApp *app) {
    if (app->input.mouseDown &&
        beastPointInsideRect(app->input.mouseX, app->input.mouseY, &app->rect)) {
        app->rect.x = app->input.mouseX - app->rect.w * 0.5f;
        app->rect.y = app->input.mouseY - app->rect.h * 0.5f;
    }
}

static void beastDraw(BeastApp *app) {
    SDL_SetRenderDrawColor(app->renderer, 20, 20, 24, 255);
    SDL_RenderClear(app->renderer);

    SDL_FRect rect = {
        app->rect.x,
        app->rect.y,
        app->rect.w,
        app->rect.h
    };

    SDL_SetRenderDrawColor(app->renderer, 255, 122, 60, 255);
    SDL_RenderFillRect(app->renderer, &rect);

    SDL_RenderPresent(app->renderer);
}

int main(int argc, char *argv[]) {
    (void)argc;
    (void)argv;

    BeastApp app = {0};
    app.running = true;
    app.rect = (BeastRect){100.0f, 100.0f, 240.0f, 140.0f};

    if (!SDL_Init(SDL_INIT_VIDEO)) {
        SDL_Log("SDL_Init failed: %s", SDL_GetError());
        return 1;
    }

    app.window = SDL_CreateWindow("beast sdl3 starter", 1280, 720, 0);
    if (!app.window) {
        SDL_Log("SDL_CreateWindow failed: %s", SDL_GetError());
        SDL_Quit();
        return 1;
    }

    app.renderer = SDL_CreateRenderer(app.window, NULL);
    if (!app.renderer) {
        SDL_Log("SDL_CreateRenderer failed: %s", SDL_GetError());
        SDL_DestroyWindow(app.window);
        SDL_Quit();
        return 1;
    }

    while (app.running) {
        SDL_Event event;
        while (SDL_PollEvent(&event)) {
            beastHandleEvent(&app, &event);
        }

        beastUpdate(&app);
        beastDraw(&app);
    }

    SDL_DestroyRenderer(app.renderer);
    SDL_DestroyWindow(app.window);
    SDL_Quit();
    return 0;
}

