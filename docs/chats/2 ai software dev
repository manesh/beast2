// beast_sokol_starter.c
//
// Minimal Beast + sokol starter.
// Opens a window, clears screen, and draws one rectangle.
// No text, no input widgets, no dispatcher yet.
//
// Build notes:
// - You need sokol_app.h, sokol_gfx.h, sokol_glue.h, and sokol_log.h available.
// - This example uses the sokol shape helper for fastest startup.
// - If you do not want sokol_shape, I can give you a version with raw vertices.
//
// Typical compile depends on platform/backend. Keep this as the app shell first.

#include <stdbool.h>
#include <stdint.h>
#include <string.h>

#define SOKOL_IMPL
#define SOKOL_GLUE_IMPL
#define SOKOL_LOG_IMPL
#include "sokol_app.h"
#include "sokol_gfx.h"
#include "sokol_glue.h"
#include "sokol_log.h"

#define SOKOL_SHAPE_IMPL
#include "sokol_shape.h"

typedef struct BeastRect {
    float x;
    float y;
    float w;
    float h;
    uint32_t color;
} BeastRect;

typedef struct BeastInput {
    float mouseX;
    float mouseY;
    bool mouseDown;
} BeastInput;

typedef struct BeastApp {
    sg_pass_action passAction;
    sg_pipeline pipeline;
    sg_bindings bindings;
    BeastInput input;
    BeastRect testRect;
} BeastApp;

static BeastApp gBeastApp;

typedef struct BeastVertex {
    float x;
    float y;
    uint32_t color;
} BeastVertex;

static BeastVertex gVertices[4];
static uint16_t gIndices[6] = {0, 1, 2, 0, 2, 3};

static void beastUpdateRectGeometry(const BeastRect *rect) {
    // Convert from pixel coordinates to normalized device coords.
    const float fbw = (float)sapp_widthf();
    const float fbh = (float)sapp_heightf();

    const float x0 = (rect->x / fbw) * 2.0f - 1.0f;
    const float y0 = 1.0f - (rect->y / fbh) * 2.0f;
    const float x1 = ((rect->x + rect->w) / fbw) * 2.0f - 1.0f;
    const float y1 = 1.0f - ((rect->y + rect->h) / fbh) * 2.0f;

    gVertices[0] = (BeastVertex){ .x = x0, .y = y0, .color = rect->color };
    gVertices[1] = (BeastVertex){ .x = x1, .y = y0, .color = rect->color };
    gVertices[2] = (BeastVertex){ .x = x1, .y = y1, .color = rect->color };
    gVertices[3] = (BeastVertex){ .x = x0, .y = y1, .color = rect->color };

    sg_update_buffer(gBeastApp.bindings.vertex_buffers[0], &(sg_range){
        .ptr = gVertices,
        .size = sizeof(gVertices)
    });
}

static void beastHandleInput(const sapp_event *event) {
    switch (event->type) {
        case SAPP_EVENTTYPE_MOUSE_MOVE:
            gBeastApp.input.mouseX = event->mouse_x;
            gBeastApp.input.mouseY = event->mouse_y;
            break;

        case SAPP_EVENTTYPE_MOUSE_DOWN:
            gBeastApp.input.mouseDown = true;
            gBeastApp.input.mouseX = event->mouse_x;
            gBeastApp.input.mouseY = event->mouse_y;
            break;

        case SAPP_EVENTTYPE_MOUSE_UP:
            gBeastApp.input.mouseDown = false;
            gBeastApp.input.mouseX = event->mouse_x;
            gBeastApp.input.mouseY = event->mouse_y;
            break;

        default:
            break;
    }
}

static bool beastPointInsideRect(float x, float y, const BeastRect *rect) {
    return
        (x >= rect->x) &&
        (x <= (rect->x + rect->w)) &&
        (y >= rect->y) &&
        (y <= (rect->y + rect->h));
}

static void beastUpdate(void) {
    // Minimal input-driven behavior:
    // if mouse held inside rectangle, drag it by centering on cursor.
    if (gBeastApp.input.mouseDown &&
        beastPointInsideRect(gBeastApp.input.mouseX, gBeastApp.input.mouseY, &gBeastApp.testRect)) {
        gBeastApp.testRect.x = gBeastApp.input.mouseX - (gBeastApp.testRect.w * 0.5f);
        gBeastApp.testRect.y = gBeastApp.input.mouseY - (gBeastApp.testRect.h * 0.5f);
    }

    beastUpdateRectGeometry(&gBeastApp.testRect);
}

static void beastDraw(void) {
    sg_begin_pass(&(sg_pass){
        .action = gBeastApp.passAction,
        .swapchain = sglue_swapchain()
    });

    sg_apply_pipeline(gBeastApp.pipeline);
    sg_apply_bindings(&gBeastApp.bindings);
    sg_draw(0, 6, 1);

    sg_end_pass();
    sg_commit();
}

static void beastInit(void) {
    memset(&gBeastApp, 0, sizeof(gBeastApp));

    sg_setup(&(sg_desc){
        .environment = sglue_environment(),
        .logger.func = slog_func
    });

    gBeastApp.passAction = (sg_pass_action){
        .colors[0] = {
            .load_action = SG_LOADACTION_CLEAR,
            .clear_value = { 0.08f, 0.08f, 0.10f, 1.0f }
        }
    };

    gBeastApp.testRect = (BeastRect){
        .x = 100.0f,
        .y = 100.0f,
        .w = 240.0f,
        .h = 140.0f,
        .color = 0xFF7A3CFFu
    };

    gBeastApp.bindings.vertex_buffers[0] = sg_make_buffer(&(sg_buffer_desc){
        .usage = SG_USAGE_STREAM,
        .size = sizeof(gVertices),
        .label = "beast-rect-vertices"
    });

    gBeastApp.bindings.index_buffer = sg_make_buffer(&(sg_buffer_desc){
        .type = SG_BUFFERTYPE_INDEXBUFFER,
        .data = SG_RANGE(gIndices),
        .label = "beast-rect-indices"
    });

    sg_shader shader = sg_make_shader(&(sg_shader_desc){
        .vertex_func = {
            .source =
                "#version 330\n"
                "layout(location=0) in vec2 position;\n"
                "layout(location=1) in vec4 color0;\n"
                "out vec4 color;\n"
                "void main() {\n"
                "    gl_Position = vec4(position, 0.0, 1.0);\n"
                "    color = color0;\n"
                "}\n"
        },
        .fragment_func = {
            .source =
                "#version 330\n"
                "in vec4 color;\n"
                "out vec4 frag_color;\n"
                "void main() {\n"
                "    frag_color = color;\n"
                "}\n"
        },
        .attrs = {
            [0].name = "position",
            [1].name = "color0"
        },
        .label = "beast-basic-shader"
    });

    gBeastApp.pipeline = sg_make_pipeline(&(sg_pipeline_desc){
        .shader = shader,
        .layout = {
            .buffers[0].stride = sizeof(BeastVertex),
            .attrs = {
                [0] = {
                    .format = SG_VERTEXFORMAT_FLOAT2,
                    .offset = offsetof(BeastVertex, x)
                },
                [1] = {
                    .format = SG_VERTEXFORMAT_UBYTE4N,
                    .offset = offsetof(BeastVertex, color)
                }
            }
        },
        .index_type = SG_INDEXTYPE_UINT16,
        .label = "beast-basic-pipeline"
    });

    beastUpdateRectGeometry(&gBeastApp.testRect);
}

static void beastFrame(void) {
    beastUpdate();
    beastDraw();
}

static void beastCleanup(void) {
    sg_shutdown();
}

static void beastEvent(const sapp_event *event) {
    beastHandleInput(event);
}

sapp_desc sokol_main(int argc, char *argv[]) {
    (void)argc;
    (void)argv;

    return (sapp_desc){
        .init_cb = beastInit,
        .frame_cb = beastFrame,
        .cleanup_cb = beastCleanup,
        .event_cb = beastEvent,
        .width = 1280,
        .height = 720,
        .window_title = "beast sokol starter",
        .logger.func = slog_func
    };
}

