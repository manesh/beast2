// beast_sdl3_shell.c
//
// Minimal Beast SDL3 shell.
// - opens window
// - draws gallery panel
// - draws command bar
// - draws fake generate button
// - clicking button inserts a colored tile into gallery
//
// Requires SDL3.
//
// Build idea:
// clang beast_sdl3_shell.c -o beast_sdl3_shell `sdl3-config --cflags --libs`
//
// On some setups you may instead use pkg-config:
// clang beast_sdl3_shell.c -o beast_sdl3_shell `pkg-config --cflags --libs sdl3`

#include <SDL3/SDL.h>
#include <SDL3/SDL_main.h>
#include <stdbool.h>
#include <stdint.h>
#include <string.h>

#define BEAST_MAX_GALLERY_ITEMS 256

typedef struct BeastRect {
    float x;
    float y;
    float w;
    float h;
} BeastRect;

typedef struct BeastColor {
    uint8_t r;
    uint8_t g;
    uint8_t b;
    uint8_t a;
} BeastColor;

typedef struct BeastInput {
    float mouseX;
    float mouseY;
    bool mouseDown;
    bool mousePressed;
    bool mouseReleased;
} BeastInput;

typedef struct BeastGalleryItem {
    BeastColor color;
} BeastGalleryItem;

typedef struct BeastGallery {
    BeastGalleryItem items[BEAST_MAX_GALLERY_ITEMS];
    uint32_t itemCount;
} BeastGallery;

typedef struct BeastUiLayout {
    BeastRect windowRect;
    BeastRect topBarRect;
    BeastRect galleryRect;
    BeastRect commandBarRect;
    BeastRect generateButtonRect;
} BeastUiLayout;

typedef struct BeastApp {
    SDL_Window *window;
    SDL_Renderer *renderer;
    bool running;

    BeastInput input;
    BeastGallery gallery;
    BeastUiLayout layout;

    uint32_t fakeColorSeed;
} BeastApp;

static bool beastPointInsideRect(float x, float y, const BeastRect *rect) {
    return
        (x >= rect->x) &&
        (x <= rect->x + rect->w) &&
        (y >= rect->y) &&
        (y <= rect->y + rect->h);
}

static SDL_FRect beastToSdlRect(const BeastRect *rect) {
    SDL_FRect out = {
        rect->x,
        rect->y,
        rect->w,
        rect->h
    };
    return out;
}

static void beastDrawRect(
    SDL_Renderer *renderer,
    const BeastRect *rect,
    BeastColor color)
{
    SDL_SetRenderDrawColor(renderer, color.r, color.g, color.b, color.a);
    SDL_FRect sdlRect = beastToSdlRect(rect);
    SDL_RenderFillRect(renderer, &sdlRect);
}

static void beastDrawRectOutline(
    SDL_Renderer *renderer,
    const BeastRect *rect,
    BeastColor color)
{
    SDL_SetRenderDrawColor(renderer, color.r, color.g, color.b, color.a);
    SDL_FRect sdlRect = beastToSdlRect(rect);
    SDL_RenderRect(renderer, &sdlRect);
}

static BeastColor beastMakeFakeColor(uint32_t seed) {
    BeastColor color;
    color.r = (uint8_t)(80 + (seed * 53) % 160);
    color.g = (uint8_t)(80 + (seed * 97) % 160);
    color.b = (uint8_t)(80 + (seed * 193) % 160);
    color.a = 255;
    return color;
}

static void beastResetPerFrameInput(BeastInput *input) {
    input->mousePressed = false;
    input->mouseReleased = false;
}

static void beastHandleEvent(BeastApp *app, const SDL_Event *event) {
    switch (event->type) {
        case SDL_EVENT_QUIT:
            app->running = false;
            break;

        case SDL_EVENT_MOUSE_MOTION:
            app->input.mouseX = event->motion.x;
            app->input.mouseY = event->motion.y;
            break;

        case SDL_EVENT_MOUSE_BUTTON_DOWN:
            if (event->button.button == SDL_BUTTON_LEFT) {
                app->input.mouseDown = true;
                app->input.mousePressed = true;
                app->input.mouseX = event->button.x;
                app->input.mouseY = event->button.y;
            }
            break;

        case SDL_EVENT_MOUSE_BUTTON_UP:
            if (event->button.button == SDL_BUTTON_LEFT) {
                app->input.mouseDown = false;
                app->input.mouseReleased = true;
                app->input.mouseX = event->button.x;
                app->input.mouseY = event->button.y;
            }
            break;

        default:
            break;
    }
}

static void beastUpdateLayout(BeastApp *app) {
    int windowWidth = 0;
    int windowHeight = 0;
    SDL_GetWindowSize(app->window, &windowWidth, &windowHeight);

    app->layout.windowRect = (BeastRect){
        .x = 0.0f,
        .y = 0.0f,
        .w = (float)windowWidth,
        .h = (float)windowHeight
    };

    const float padding = 16.0f;
    const float topBarHeight = 56.0f;
    const float commandBarHeight = 88.0f;

    app->layout.topBarRect = (BeastRect){
        .x = padding,
        .y = padding,
        .w = (float)windowWidth - padding * 2.0f,
        .h = topBarHeight
    };

    app->layout.commandBarRect = (BeastRect){
        .x = padding,
        .y = (float)windowHeight - commandBarHeight - padding,
        .w = (float)windowWidth - padding * 2.0f,
        .h = commandBarHeight
    };

    app->layout.galleryRect = (BeastRect){
        .x = padding,
        .y = app->layout.topBarRect.y + app->layout.topBarRect.h + padding,
        .w = (float)windowWidth - padding * 2.0f,
        .h = app->layout.commandBarRect.y
            - (app->layout.topBarRect.y + app->layout.topBarRect.h)
            - padding * 2.0f
    };

    app->layout.generateButtonRect = (BeastRect){
        .x = app->layout.commandBarRect.x + 16.0f,
        .y = app->layout.commandBarRect.y + 16.0f,
        .w = 180.0f,
        .h = app->layout.commandBarRect.h - 32.0f
    };
}

static void beastInsertFakeGalleryItem(BeastApp *app) {
    if (app->gallery.itemCount >= BEAST_MAX_GALLERY_ITEMS) {
        return;
    }

    BeastGalleryItem *item = &app->gallery.items[app->gallery.itemCount];
    item->color = beastMakeFakeColor(app->fakeColorSeed++);
    app->gallery.itemCount += 1;
}

static void beastUpdate(BeastApp *app) {
    beastUpdateLayout(app);

    if (app->input.mousePressed) {
        if (beastPointInsideRect(
                app->input.mouseX,
                app->input.mouseY,
                &app->layout.generateButtonRect)) {
            beastInsertFakeGalleryItem(app);
        }
    }
}

static void beastDrawGallery(BeastApp *app) {
    const BeastColor panelColor = {28, 28, 34, 255};
    const BeastColor outlineColor = {80, 80, 96, 255};

    beastDrawRect(app->renderer, &app->layout.galleryRect, panelColor);
    beastDrawRectOutline(app->renderer, &app->layout.galleryRect, outlineColor);

    const float padding = 12.0f;
    const float tileSize = 96.0f;
    const float gap = 12.0f;

    float x = app->layout.galleryRect.x + padding;
    float y = app->layout.galleryRect.y + padding;
    const float rightLimit = app->layout.galleryRect.x + app->layout.galleryRect.w - padding;

    for (uint32_t i = 0; i < app->gallery.itemCount; ++i) {
        if (x + tileSize > rightLimit) {
            x = app->layout.galleryRect.x + padding;
            y += tileSize + gap;
        }

        BeastRect tileRect = {
            .x = x,
            .y = y,
            .w = tileSize,
            .h = tileSize
        };

        beastDrawRect(app->renderer, &tileRect, app->gallery.items[i].color);

        BeastColor tileOutline = {18, 18, 22, 255};
        beastDrawRectOutline(app->renderer, &tileRect, tileOutline);

        x += tileSize + gap;
    }
}

static void beastDrawTopBar(BeastApp *app) {
    BeastColor topBarColor = {22, 22, 28, 255};
    BeastColor outlineColor = {70, 70, 90, 255};

    beastDrawRect(app->renderer, &app->layout.topBarRect, topBarColor);
    beastDrawRectOutline(app->renderer, &app->layout.topBarRect, outlineColor);

    BeastRect accent = {
        .x = app->layout.topBarRect.x + 12.0f,
        .y = app->layout.topBarRect.y + 12.0f,
        .w = 120.0f,
        .h = app->layout.topBarRect.h - 24.0f
    };
    BeastColor accentColor = {255, 122, 60, 255};
    beastDrawRect(app->renderer, &accent, accentColor);
}

static void beastDrawCommandBar(BeastApp *app) {
    BeastColor barColor = {20, 20, 26, 255};
    BeastColor outlineColor = {80, 80, 96, 255};

    beastDrawRect(app->renderer, &app->layout.commandBarRect, barColor);
    beastDrawRectOutline(app->renderer, &app->layout.commandBarRect, outlineColor);

    const bool hovered = beastPointInsideRect(
        app->input.mouseX,
        app->input.mouseY,
        &app->layout.generateButtonRect);

    BeastColor buttonColor = hovered
        ? (BeastColor){255, 150, 90, 255}
        : (BeastColor){255, 122, 60, 255};

    beastDrawRect(app->renderer, &app->layout.generateButtonRect, buttonColor);

    BeastColor buttonOutline = {30, 20, 12, 255};
    beastDrawRectOutline(app->renderer, &app->layout.generateButtonRect, buttonOutline);

    BeastRect fakePromptBox = {
        .x = app->layout.generateButtonRect.x + app->layout.generateButtonRect.w + 16.0f,
        .y = app->layout.commandBarRect.y + 16.0f,
        .w = app->layout.commandBarRect.w - app->layout.generateButtonRect.w - 48.0f,
        .h = app->layout.commandBarRect.h - 32.0f
    };

    BeastColor promptColor = {32, 32, 40, 255};
    BeastColor promptOutline = {90, 90, 108, 255};

    beastDrawRect(app->renderer, &fakePromptBox, promptColor);
    beastDrawRectOutline(app->renderer, &fakePromptBox, promptOutline);
}

static void beastDraw(BeastApp *app) {
    SDL_SetRenderDrawColor(app->renderer, 12, 12, 16, 255);
    SDL_RenderClear(app->renderer);

    beastDrawTopBar(app);
    beastDrawGallery(app);
    beastDrawCommandBar(app);

    SDL_RenderPresent(app->renderer);
}

int main(int argc, char *argv[]) {
    (void)argc;
    (void)argv;

    BeastApp app;
    memset(&app, 0, sizeof(app));
    app.running = true;
    app.fakeColorSeed = 1;

    if (!SDL_Init(SDL_INIT_VIDEO)) {
        SDL_Log("SDL_Init failed: %s", SDL_GetError());
        return 1;
    }

    app.window = SDL_CreateWindow(
        "beast sdl3 shell",
        1280,
        720,
        SDL_WINDOW_RESIZABLE);

    if (!app.window) {
        SDL_Log("SDL_CreateWindow failed: %s", SDL_GetError());
        SDL_Quit();
        return 1;
    }

    app.renderer = SDL_CreateRenderer(app.window, NULL);
    if (!app.renderer) {
        SDL_Log("SDL_CreateRenderer failed: %s", SDL_GetError());
        SDL_DestroyWindow(app.window);
        SDL_Quit();
        return 1;
    }

    while (app.running) {
        beastResetPerFrameInput(&app.input);

        SDL_Event event;
        while (SDL_PollEvent(&event)) {
            beastHandleEvent(&app, &event);
        }

        beastUpdate(&app);
        beastDraw(&app);

        SDL_Delay(16);
    }

    SDL_DestroyRenderer(app.renderer);
    SDL_DestroyWindow(app.window);
    SDL_Quit();
    return 0;
}

