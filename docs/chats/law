-- beast schema
-- words carry meaning
-- ids anchor truth
-- letters optional

CREATE TABLE lexeme (
    lexeme_id TEXT PRIMARY KEY,          -- e.g. dir.forward.1
    term TEXT NOT NULL UNIQUE,           -- e.g. forward
    kind TEXT NOT NULL,                  -- word | name | title | meme | axiom
    state INTEGER NOT NULL DEFAULT 0,    -- -1 0 1
    gematria INTEGER,                    -- 0..9 if mapped
    definition TEXT NOT NULL DEFAULT '',
    notes TEXT NOT NULL DEFAULT '',
    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_lexeme_kind ON lexeme(kind);
CREATE INDEX idx_lexeme_state ON lexeme(state);
CREATE INDEX idx_lexeme_gematria ON lexeme(gematria);

CREATE TABLE lexeme_alias (
    alias_id INTEGER PRIMARY KEY AUTOINCREMENT,
    lexeme_id TEXT NOT NULL,
    alias TEXT NOT NULL,
    alias_kind TEXT NOT NULL DEFAULT 'alias', -- alias | phonetic | meme | shorthand
    UNIQUE(lexeme_id, alias),
    FOREIGN KEY (lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE
);

CREATE INDEX idx_lexeme_alias_alias ON lexeme_alias(alias);

CREATE TABLE lexeme_vector (
    lexeme_id TEXT PRIMARY KEY,
    dim_count INTEGER NOT NULL,
    vector_json TEXT NOT NULL,           -- stable ordered array
    is_anchor INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE
);

CREATE TABLE lexeme_token (
    token_id INTEGER PRIMARY KEY AUTOINCREMENT,
    lexeme_id TEXT NOT NULL,
    position INTEGER NOT NULL,
    token TEXT NOT NULL,                 -- letter or subtoken
    UNIQUE(lexeme_id, position),
    FOREIGN KEY (lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE
);

CREATE INDEX idx_lexeme_token_token ON lexeme_token(token);

CREATE TABLE lexeme_relation (
    relation_id INTEGER PRIMARY KEY AUTOINCREMENT,
    src_lexeme_id TEXT NOT NULL,
    rel_type TEXT NOT NULL,              -- synonym | opposite | meme | lineage | title_of
    dst_lexeme_id TEXT NOT NULL,
    weight REAL NOT NULL DEFAULT 1.0,
    notes TEXT NOT NULL DEFAULT '',
    UNIQUE(src_lexeme_id, rel_type, dst_lexeme_id),
    FOREIGN KEY (src_lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE,
    FOREIGN KEY (dst_lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE
);

CREATE INDEX idx_lexeme_relation_src ON lexeme_relation(src_lexeme_id, rel_type);
CREATE INDEX idx_lexeme_relation_dst ON lexeme_relation(dst_lexeme_id, rel_type);

CREATE TABLE artifact (
    artifact_id TEXT PRIMARY KEY,        -- stable id
    title TEXT NOT NULL,
    artifact_type TEXT NOT NULL,         -- story | cheatSheet | law | log | preferences
    state INTEGER NOT NULL DEFAULT 0,
    body TEXT NOT NULL,
    source_context TEXT NOT NULL DEFAULT '',
    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_artifact_type ON artifact(artifact_type);
CREATE INDEX idx_artifact_state ON artifact(state);

CREATE TABLE artifact_lexeme (
    artifact_id TEXT NOT NULL,
    lexeme_id TEXT NOT NULL,
    role TEXT NOT NULL DEFAULT 'mentions', -- defines | mentions | expands | anchors
    PRIMARY KEY (artifact_id, lexeme_id, role),
    FOREIGN KEY (artifact_id) REFERENCES artifact(artifact_id) ON DELETE CASCADE,
    FOREIGN KEY (lexeme_id) REFERENCES lexeme(lexeme_id) ON DELETE CASCADE
);

CREATE INDEX idx_artifact_lexeme_lexeme ON artifact_lexeme(lexeme_id, role);

CREATE TABLE lineage (
    lineage_id INTEGER PRIMARY KEY AUTOINCREMENT,
    target_kind TEXT NOT NULL,           -- lexeme | artifact
    target_id TEXT NOT NULL,
    generator TEXT NOT NULL,
    parent_kind TEXT NOT NULL DEFAULT '',
    parent_id TEXT NOT NULL DEFAULT '',
    reason TEXT NOT NULL DEFAULT '',
    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX idx_lineage_target ON lineage(target_kind, target_id);

CREATE TABLE ingest_log (
    ingest_id INTEGER PRIMARY KEY AUTOINCREMENT,
    raw_text TEXT NOT NULL,
    parsed_kind TEXT NOT NULL DEFAULT '',   -- lexeme | artifact | unknown
    parsed_target_id TEXT NOT NULL DEFAULT '',
    result_state INTEGER NOT NULL DEFAULT 0,
    reason TEXT NOT NULL DEFAULT '',
    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

