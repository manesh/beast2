# Phase 11 knowledge database example

$b2_generator
b2_name qwen_local_encyclopedia_demo

$b2_positive_prompt
b2_section request
b2_snippet Describe a moonlit fortress scene with accurate environmental context

$b2_tags
b2_tag example
b2_tag qwen
b2_tag knowledge-db

$b2_workflow
b2_engine qwen
b2_checkpoint qwen#knowledge010
b2_backend llama.cpp
b2_precision int8
b2_model_type llm
b2_llm_task knowledge_query
b2_llm_instruction summarize relevant encyclopedia context for the scene
b2_knowledge_source local_encyclopedia
b2_knowledge_terms moonlit fortress cliff lighting
